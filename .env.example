# Client (Vite — exposed to browser, prefix VITE_)
VITE_NEON_AUTH_URL=https://YOUR_PROJECT.neonauth.REGION.aws.neon.tech/neondb/auth
VITE_NEON_DATA_API_URL=https://YOUR_PROJECT.REGION.aws.neon.tech/neondb/rest/v1

# Server (Vercel Functions — never prefix with VITE_)
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — local scripts only (do not need on Vercel unless running migrations there)
DATABASE_URL=postgresql://...
